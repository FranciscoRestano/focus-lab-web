---
// src/components/Testimonials.astro
const testimonials = [
  {
    text: "Focus Lab transformó nuestra presencia en redes. Empezamos a recibir consultas que antes no llegaban.",
    author: "Juan Pérez",
    company: "Algaba"
  },
  {
    text: "Muy profesionales y ordenados. Se nota que saben lo que hacen. Recomendados.",
    author: "María González",
    company: "iShop Paraná"
  },
  {
    text: "Desde que trabajamos con Focus Lab nuestra marca tiene otra imagen. Vale cada peso.",
    author: "Carlos López",
    company: "Tercer Tiempo"
  }
];
---

<section id="testimonios" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-2xl md:text-4xl font-bold text-center text-focus-dark mb-12 md:mb-16 tracking-tight">
      Lo que dicen nuestros clientes
    </h2>
    
    <div class="flex flex-col md:flex-row gap-6 md:gap-8 justify-center">
      {testimonials.map((t) => (
        <div class="flex flex-col justify-between p-8 bg-focus-white rounded-2xl border border-gray-100/50 shadow-sm md:w-1/3 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
          {/* Tarjetas con tu gris real (bg-focus-white) para que contrasten sobre el fondo blanco */}
          <p class="text-base text-focus-dark/80 italic leading-relaxed mb-6">
            "{t.text}"
          </p>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-focus-dark">
              {t.author}
            </span>
            <span class="text-xs font-semibold text-focus-blue uppercase tracking-wider mt-1">
              {t.company}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>