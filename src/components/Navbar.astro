---
import { Image } from 'astro:assets';
import logoAzul from '../assets/logo-azul.png';
---

<nav class="fixed w-full z-50 bg-focus-bg/80 backdrop-blur-md border-b border-focus-dark/10">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="transition-opacity hover:opacity-80">
      <Image src={logoAzul} alt="Focus Lab Logo" class="h-10 w-auto" />
    </a>

    <div class="hidden md:flex gap-8 text-sm font-medium uppercase tracking-widest text-focus-dark">
      <a href="/#servicios" class="hover:text-focus-blue transition-colors">Servicios</a>
      <a href="/#portfolio" class="hover:text-focus-blue transition-colors">Portafolio</a>
      <a href="/nosotros" class="hover:text-focus-blue transition-colors">Nosotros</a>
      <a href="/#contacto" class="hover:text-focus-blue transition-colors">Contacto</a>
    </div>

    <a href="https://wa.link/kz1tq1" target="_blank" rel="noopener noreferrer" class="hidden md:block bg-focus-dark text-white px-5 py-2 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-focus-blue transition-all">
      Contactanos
    </a>

    <button id="menu-btn" class="md:hidden text-focus-dark">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>
</nav>

<div id="mobile-menu" class="hidden fixed inset-0 bg-white z-50 flex flex-col items-center justify-center gap-10 text-3xl font-bold uppercase tracking-[0.2em] text-focus-dark">
  <button id="close-btn" class="absolute top-8 right-8 text-xs tracking-widest uppercase border border-gray-200 px-4 py-2 rounded-full">
    Cerrar ×
  </button>
  <a href="/#servicios" class="nav-link-mobile">Servicios</a>
  <a href="/#portfolio" class="nav-link-mobile">Portafolio</a>
  <a href="/nosotros" class="nav-link-mobile">Nosotros</a>
  <a href="/#contacto" class="nav-link-mobile">Contacto</a>
</div>

<script>
  // Script robusto que previene duplicados en Astro ClientRouter
  const initMenu = () => {
    const mobileMenu = document.getElementById('mobile-menu');
    const openBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const navLinks = document.querySelectorAll('.nav-link-mobile');

    if (!openBtn || !mobileMenu) return;

    // Lógica para prevenir duplicados: removemos listeners viejos si existen
    openBtn.replaceWith(openBtn.cloneNode(true));
    closeBtn?.replaceWith(closeBtn?.cloneNode(true) || "");

    const newOpenBtn = document.getElementById('menu-btn');
    const newCloseBtn = document.getElementById('close-btn');

    const openMenu = () => {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      document.body.style.overflow = 'auto';
    };

    newOpenBtn?.addEventListener('click', openMenu);
    newCloseBtn?.addEventListener('click', closeMenu);
    
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        // Si es un ancla interna de la One-Page, cerramos el menú manual
        if (href && href.includes('#')) {
          closeMenu();
        } 
        // Si es una página nueva (como /nosotros), el menú se cierra solo al recargar
      });
    });
  };

  // Astro dispara este evento después de la transición de View Transitions
  document.addEventListener('astro:page-load', initMenu);
  // Y este para la primera carga
  document.addEventListener('DOMContentLoaded', initMenu);
</script>