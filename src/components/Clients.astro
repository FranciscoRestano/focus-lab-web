---
import { Image } from 'astro:assets';

import logoAlgaba from '../assets/logo-algaba.svg';
import logoTercerTiempo from '../assets/logo-tercer-tiempo.svg';
import logoDobleJ from '../assets/logo-doblej.svg';
import logoSocAle from '../assets/logo-soc-ale.svg';
import logoIshop from '../assets/logo-ishop.svg';
import logoConexion from '../assets/logo-conexionsrl.svg';
import logoBlackSentinel from '../assets/logo-blacksentinel.png';

const clients = [
  { img: logoAlgaba, name: "Algaba" },
  { img: logoTercerTiempo, name: "Tercer Tiempo" },
  { img: logoDobleJ, name: "Doble J" },
  { img: logoSocAle, name: "Soc. Alemana" },
  { img: logoIshop, name: "iShop" },
  { img: logoConexion, name: "Conexión SRL" },
  { img: logoBlackSentinel, name: "Black Sentinel" },
];
---

{/* Añadido overflow-hidden a la sección principal para evitar scrollbar horizontal en la página */}
<section id="clientes" class="mt-12 md:mt-32 py-16 md:py-20 bg-focus-white scroll-mt-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 mb-12">
    <span class="text-focus-blue font-bold tracking-[0.2em] uppercase text-[10px] block text-center">
      Dirección estratégica para marcas líderes
    </span>
  </div>

  {/* Contenedor del carrusel con máscara de desvanecimiento en los bordes */}
  <div class="relative w-full overflow-hidden mask-linear">
    {/* El contenedor contenedor mide w-max para albergar ambas listas en una sola línea */}
    <div class="flex w-max gap-16 md:gap-24 animate-marquee py-4">
      
      {/* Bloque de logos 1 */}
     <div class="flex w-max gap-20 md:gap-32 animate-marquee py-4">

  <div class="flex gap-20 md:gap-32 shrink-0 items-center">
    {clients.map((client) => (

      <div class="flex flex-col items-center justify-center group gap-4 md:gap-5 w-36 md:w-60 shrink-0">
        
        <div class="h-16 md:h-28 flex items-center justify-center w-full">
          <Image 
            src={client.img} 
            alt={client.name} 
            class="h-full w-auto object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 ease-out"
          />
        </div>
        
        <span class="text-[9px] md:text-[11px] font-bold uppercase tracking-[0.2em] text-focus-dark/30 group-hover:text-focus-blue transition-colors duration-500 text-center">
          {client.name}
        </span>
      </div>
    ))}
  </div>

      {/* Bloque de logos 2 (Duplicado idéntico para simular bucle infinito sin saltos en blanco) */}
      <div class="flex gap-16 md:gap-24 shrink-0 items-center" aria-hidden="true">
        {clients.map((client) => (
          <div class="flex flex-col items-center justify-center group gap-3 md:gap-4 w-28 md:w-40 shrink-0">
            <div class="h-12 md:h-20 flex items-center justify-center w-full">
              <Image 
                src={client.img} 
                alt={client.name} 
                class="h-full w-auto object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 ease-out"
              />
            </div>
            <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-[0.2em] text-focus-dark/30 group-hover:text-focus-blue transition-colors duration-500 text-center">
              {client.name}
            </span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Se desplaza exactamente la mitad (el primer bloque completo) antes de reiniciarse instantáneamente */
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    /* ANTES: 30s */
    /* PROPUESTA: 40s o 45s para que sea un movimiento sutil y legible */
    animation: marquee 45s linear infinite;
  }

  /* Oclusión ambiental difuminada para que los logos no se corten bruscamente en los bordes de la pantalla */
  .mask-linear {
    mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
  }
</style>