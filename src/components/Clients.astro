---
import { Image } from 'astro:assets';

import logoAlgaba from '../assets/logo-algaba.svg';
import logoTercerTiempo from '../assets/logo-tercer-tiempo.svg';
import logoDobleJ from '../assets/logo-doblej.svg';
import logoSocAle from '../assets/logo-soc-ale.svg';
import logoIshop from '../assets/logo-ishop.svg';
import logoConexion from '../assets/logo-conexionsrl.svg';
import logoBlackSentinel from '../assets/logo-blacksentinel.png';

const clients = [
  { img: logoAlgaba, name: "Algaba" },
  { img: logoTercerTiempo, name: "Tercer Tiempo" },
  { img: logoDobleJ, name: "Doble J" },
  { img: logoSocAle, name: "Soc. Alemana" },
  { img: logoIshop, name: "iShop" },
  { img: logoConexion, name: "Conexión SRL" },
  { img: logoBlackSentinel, name: "Black Sentinel" },
];
---

<section id="clientes" class="py-24 md:py-40 bg-white border-t border-gray-50 scroll-mt-24">
  <div class="max-w-7xl mx-auto px-6">
    <span class="text-focus-blue font-bold tracking-[0.2em] uppercase text-[10px] mb-24 block text-center">
      Dirección estratégica para marcas líderes
    </span>
    
    <div class="flex flex-wrap justify-center gap-x-16 gap-y-24">
      {clients.map((client) => (
        <div class="flex flex-col items-center justify-center group gap-6 w-full sm:w-[calc(45%-1rem)] lg:w-[calc(22%-1rem)]">
          <div class="h-20 md:h-28 flex items-center justify-center">
            <Image 
              src={client.img} 
              alt={client.name} 
              class="h-full w-auto object-contain grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-out"
            />
          </div>
          
          <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-focus-dark/30 group-hover:text-focus-blue transition-colors duration-500 text-center">
            {client.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>