---
import { services } from '../data/services.js';
---

<section id="servicios" class="py-24 md:py-32 px-6 bg-focus-white">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 md:mb-24 text-center md:text-left">
      <span class="text-focus-blue font-bold tracking-[0.2em] uppercase text-[10px] mb-4 block">Nuestras Soluciones</span>
      <h2 class="text-4xl md:text-7xl font-bold text-focus-dark tracking-tighter leading-none">
        Servicios con <span class="italic font-light text-focus-blue">dirección</span>.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <a href={`/servicios/${service.slug}`} class="group">
          <div class="h-full p-10 rounded-[2.5rem] border border-transparent bg-white transition-all duration-500 hover:-translate-y-2 hover:border-focus-blue/30 hover:shadow-2xl hover:shadow-focus-dark/5">
            <div class="w-12 h-12 bg-focus-blue/10 rounded-2xl mb-8 flex items-center justify-center text-focus-blue font-bold group-hover:bg-focus-blue group-hover:text-white transition-all">
              0{service.id}
            </div>
            <h3 class="text-3xl font-bold text-focus-dark mb-4 group-hover:text-focus-blue transition-colors">{service.title}</h3>
            <p class="text-gray-500 font-light leading-relaxed mb-8">{service.description}</p>
            <div class="flex items-center text-focus-blue font-bold text-[10px] uppercase tracking-widest">
              Saber más 
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>