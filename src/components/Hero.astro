---
// src/components/Hero.astro
---

<section class="min-h-screen pt-28 md:pt-40 pb-20 flex flex-col items-center justify-start text-center bg-white relative overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-6 z-10">
    
    <h1 class="text-5xl md:text-7xl font-bold text-focus-dark tracking-tighter leading-tight mb-6">
      Convertimos redes <br class="hidden md:block"/> sociales en <br class="hidden md:block"/>
      <span class="text-focus-blue italic font-light">canales de venta.</span>
    </h1>
    
    <p class="text-lg md:text-xl text-gray-500 font-medium max-w-xl mx-auto mb-12 leading-relaxed">
      Estrategia, contenido y publicidad pensados para generar resultados reales.
    </p>

    <div class="flex flex-col items-center gap-10 mb-12">
      
      <a href="#portfolio" class="bg-focus-dark text-white px-14 py-5 rounded-full font-bold uppercase text-xs tracking-widest hover:scale-105 transition-transform shadow-xl shadow-focus-dark/10">
        Ver Portafolio
      </a>
      
      <div class="flex flex-col md:flex-row items-center gap-4">
        <a href="#servicios" class="bg-[#eef8f9] text-focus-blue px-10 py-4 rounded-full font-bold uppercase text-[10px] tracking-widest border border-focus-blue/10 hover:bg-white hover:border-focus-blue transition-colors w-64 md:w-auto">
          Nuestros Servicios
        </a>
        <a href="#clientes" class="bg-[#eef8f9] text-focus-blue px-10 py-4 rounded-full font-bold uppercase text-[10px] tracking-widest border border-focus-blue/10 hover:bg-white hover:border-focus-blue transition-colors w-64 md:w-auto">
          Clientes Focus
        </a>
      </div>
    </div>

   <a 
      href={`https://wa.me/${5493434666821}?text=${encodeURIComponent('Hola Focus Lab! Quiero hablar sobre un proyecto.')}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-focus-blue font-bold uppercase text-[10px] tracking-[0.2em] hover:opacity-80 transition-opacity"
      >
      Hablemos de tu proyecto —
    </a>

  </div>

  <div class="absolute inset-0 z-0">
    <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-focus-blue/3 blur-[120px]"></div>
    <div class="absolute top-[10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-focus-blue/2 blur-[100px]"></div>
  </div>
</section>