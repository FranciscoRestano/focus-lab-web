---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services.js';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const phone = "549343XXXXXXX"; // Número de Thiago
---

<Layout>
  <main class="py-24 md:py-32 px-6 bg-white min-h-screen text-focus-dark">
    <div class="max-w-4xl mx-auto">
      <span class="text-focus-blue font-bold text-[10px] uppercase tracking-widest mb-4 block">Servicio 0{service.id}</span>
      <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-none mb-12">{service.title}</h1>
      
      <div class="prose prose-xl text-gray-800 font-light leading-relaxed mb-16">
        <p>{service.content}</p>
      </div>

      <div class="pt-12 border-t border-gray-100">
        <a 
          href={`https://wa.me/${phone}?text=${encodeURIComponent(`Hola Focus Lab! Quiero más información sobre el servicio ${service.title}`)}`}
          target="_blank"
          class="inline-block bg-focus-dark text-white px-10 py-5 rounded-full font-bold text-xs uppercase tracking-widest hover:bg-focus-blue transition-all shadow-lg active:scale-95"
        >
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </main>
</Layout>