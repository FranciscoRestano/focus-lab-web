---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services.js';
---

<Layout>
  <main class="py-20 md:py-32 px-4 md:px-6 bg-white min-h-screen">
    <div class="max-w-7xl mx-auto">
      
      <div class="mb-16 md:mb-24 text-center">
        <span class="text-focus-blue font-bold tracking-[0.2em] uppercase text-[10px] mb-4 block">Nuestras Soluciones</span>
        <h1 class="text-4xl md:text-7xl font-bold text-focus-dark tracking-tighter leading-none">
          Servicios con <br class="md:hidden" /> <span class="italic font-light text-focus-blue">dirección</span>.
        </h1>
      </div>

      <div class="flex flex-wrap justify-center gap-6 md:gap-8">
        {services.map((service) => (
          <a href={`/servicios/${service.slug}`} class="group w-full md:w-[calc(33.333%-2rem)] min-w-[320px]">
            <div class="h-full p-10 rounded-[2.5rem] border border-gray-100 flex flex-col justify-between bg-white 
                        transition-all duration-500 ease-out 
                        hover:-translate-y-4 hover:border-focus-blue/30 hover:shadow-[0_20px_50px_rgba(78,175,200,0.15)]">
              
              <div>
                <div class="w-12 h-12 bg-focus-blue/10 rounded-2xl mb-8 flex items-center justify-center text-focus-blue font-bold transition-all duration-500 group-hover:bg-focus-blue group-hover:text-white">
                  0{service.id}
                </div>
                
                <h3 class="text-3xl font-bold text-focus-dark mb-4 tracking-tight group-hover:text-focus-blue transition-colors">
                  {service.title}
                </h3>
                
                <p class="text-gray-500 font-light leading-relaxed">
                  {service.description}
                </p>
              </div>

              <div class="mt-8 flex items-center text-focus-blue font-bold text-[10px] uppercase tracking-widest">
                Saber más 
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>