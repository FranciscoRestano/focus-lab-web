---
// src/pages/portafolio/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/portafolio.js';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const videoIndices = Array.from({ length: project.videoCount || 0 }, (_, i) => i + 1);
---

<Layout>
  <main class="py-24 md:py-32 px-6 bg-white min-h-screen text-focus-dark">
    <div class="max-w-7xl mx-auto">
      
      <a href="/portafolio" class="text-focus-blue font-bold text-[10px] uppercase tracking-widest flex items-center mb-12 hover:-translate-x-2 transition-transform w-fit">
        ← Volver al Portafolio
      </a>

      {/* CASO 1: El proyecto es una Imagen Estática */}
      {project.mediaType === 'image' && (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div class="space-y-8">
            <div>
              <span class="text-focus-blue font-bold text-[10px] uppercase tracking-[0.2em] mb-2 block">{project.category}</span>
              <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-none">{project.client}</h1>
            </div>
            <p class="text-2xl text-gray-800 font-light leading-tight">{project.description}</p>
            <div class="h-px bg-gray-200 w-20"></div>
            <p class="text-base text-gray-500 leading-relaxed max-w-md">{project.technicalDetail}</p>
          </div>

          <div class="flex justify-center lg:justify-end">
            <div class="w-full max-w-[550px] rounded-[2.5rem] overflow-hidden shadow-2xl bg-gray-50 border border-gray-100">
              <img src={project.src} alt={project.client} class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      )}

      {/* CASO 2: El proyecto es un Video Reel Vertical */}
      {project.mediaType === 'video' && project.type === 'reel' && (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div class="space-y-8">
            <div>
              <span class="text-focus-blue font-bold text-[10px] uppercase tracking-[0.2em] mb-2 block">{project.category}</span>
              <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-none">{project.client}</h1>
            </div>
            <p class="text-2xl text-gray-800 font-light leading-tight">{project.description}</p>
            <div class="h-px bg-gray-200 w-20"></div>
            <p class="text-base text-gray-500 leading-relaxed max-w-md">{project.technicalDetail}</p>
          </div>

          <div class="flex justify-center lg:justify-end">
            <div class="w-full max-w-[400px] rounded-[3rem] overflow-hidden border-[8px] border-focus-dark shadow-2xl aspect-[9/16] bg-gray-900">
              <video 
                src={`${project.folder}1.webm`}
                autoplay 
                loop 
                muted 
                playsinline 
                preload="auto" 
                class="w-full h-full object-cover pointer-events-none"
              ></video>
            </div>
          </div>
        </div>
      )}

      {/* CASO 3: El proyecto es una Grilla de Múltiples Videos (Doble J) */}
      {project.mediaType === 'video' && project.type !== 'reel' && (
        <div class="space-y-16 md:space-y-24">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-end">
            <div>
              <span class="text-focus-blue font-bold text-[10px] uppercase tracking-[0.2em] mb-2 block">{project.category}</span>
              <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-none">{project.client}</h1>
            </div>
            <div class="max-w-xl">
              <p class="text-xl text-gray-500 font-light leading-relaxed">{project.technicalDetail}</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {videoIndices.map((index) => (
              <div class="rounded-[2.5rem] overflow-hidden bg-gray-100 aspect-square relative border border-gray-100 shadow-sm">
                <video 
                  src={`${project.folder}${index}.webm`}
                  autoplay 
                  loop 
                  muted 
                  playsinline 
                  preload="auto" 
                  class="w-full h-full object-cover pointer-events-none"
                ></video>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>
  </main>
</Layout>

<script>
  const handleVideos = () => {
    const videos = document.querySelectorAll('video');
    
    videos.forEach(video => {
      video.muted = true;
      video.setAttribute('muted', '');
      video.setAttribute('playsinline', '');

      video.load();

      const playVideo = () => {
        const attempt = video.play();
        if (attempt !== undefined) {
          attempt.catch(() => {
            const playOnAction = () => {
              video.play();
              window.removeEventListener('mousemove', playOnAction);
              window.removeEventListener('scroll', playOnAction);
            };
            window.addEventListener('mousemove', playOnAction, { once: true });
            window.addEventListener('scroll', playOnAction, { once: true });
          });
        }
      };

      if (video.readyState >= 3) {
        playVideo();
      } else {
        video.addEventListener('canplay', playVideo, { once: true });
      }
    });
  };

  document.addEventListener('astro:page-load', handleVideos);
  document.addEventListener('DOMContentLoaded', handleVideos);
</script>